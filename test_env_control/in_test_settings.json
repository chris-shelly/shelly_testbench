{
  "autoMemoryEnabled": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/restrict-to-project.py\""
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyRead": [
        "../../results/**",
        "../../repos/**",
        "../../scripts/**",
        "../../harnesses/**",
        "../../docs/**",
        "../../.claude/**"
      ],
      "allowRead": [
        "./**",
        "/tmp/**",
        "/proc/**",
        "~/.claude/**",
        "~/.local/share/claude/**"
      ]
    }

  }
}
